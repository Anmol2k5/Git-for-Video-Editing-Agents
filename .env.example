# Companion service port (default: 8731)
EDITVCS_COMPANION_PORT=8731

# Storage root (default: .editvcs beside project)
EDITVCS_STORAGE_ROOT=.editvcs

# Log level: debug | info | warn | error (default: info)
EDITVCS_LOG_LEVEL=info

# Dev panel port for CORS allowlist (default: 5173)
EDITVCS_DEV_PANEL_PORT=5173
