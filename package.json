{
  "name": "editvcs",
  "version": "0.1.0",
  "description": "Universal version control for creative editing — for agents and humans",
  "main": "dist/cli/index.js",
  "bin": {
    "editvcs": "./dist/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dashboard": "npx -y serve dashboard -l 3333 --no-clipboard",
    "start": "node dist/cli/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "diff": "^7.0.0",
    "express": "^5.2.1",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/diff": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "version-control",
    "creative",
    "editing",
    "agents",
    "ai",
    "collaboration"
